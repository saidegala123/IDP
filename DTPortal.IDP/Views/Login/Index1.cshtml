@using Microsoft.AspNetCore.Html
@model DTPortal.IDP.ViewModel.Login.LoginViewModel
@using System.Text.Json
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Login";
    var name = Configuration["ProjectName"];
}

<link rel="stylesheet" href="~/assets/UAEID/appcss/LoginPage1.css" asp-append-version="true">

<style>
    .code-container {
        background-color: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 24px;
        padding-bottom: 3px;
        text-align: center;
    }

    .code-box {
        background-color: #D7B76B;
        padding: 5px 10px;
        padding-bottom: 0px;
        border-radius: 8px;
        display: inline-block;
    }

    .code-description {
        font-size: 14px;
        color: #4b5563;
        margin-top: 10px;
    }

    .timer-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        font-size: 12px;
        color: #6b7280;
        margin-top: 10px;
    }

    .clock-icon {
        width: 16px;
        height: 16px;
    }

</style>

<style>
    .input-wrapper {
        position: relative;
        width: 100%;
    }

        .input-wrapper input {
            width: 100%;
            padding-right: 35px;
            cursor: not-allowed;
        }

    .edit-icon {
        position: absolute;
        right: 10px;
        top: 68%;
        transform: translateY(-50%);
        cursor: pointer;
        font-size: 16px;
        display: inline;
    }

        .edit-icon:hover::after {
            content: "Click to change user";
            position: absolute;
            right: 100%;
            margin-right: 8px;
            background: #333;
            color: #fff;
            padding: 3px 7px;
            font-size: 12px;
            border-radius: 4px;
            white-space: nowrap;
        }

    .remember-me {
        margin-top: 15px;
    }

</style>

<style>
    .dialog-overlay1 {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .dialog-content1 {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        padding: 32px;
        max-width: 450px;
        width: 100%;
    }

    .header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    h1 {
        font-size: 22px;
        font-weight: 600;
        color: #333;
    }

    .instruction {
        color: #666;
        font-size: 14px;
        margin-bottom: 20px;
    }

    #video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .user-info-container {
        margin-bottom: 20px;
    }

    .label {
        font-size: 15px;
        font-weight: 500;
        color: #333;
        margin-bottom: 6px;
        display: block;
    }

    .user-display {
        position: relative;
        display: inline-block;
        width: 100%;
    }

    .user-info-container {
        width: 100%;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 6px;
        font-size: 14px;
        color: #333;
        background: #FCFBFB80;
        transition: all 0.3s ease;
        cursor: default;
    }

    .user-display:hover .user-email-box {
        border-color: #4A90E2;
        background: #f0f7ff;
    }

    .change-user-btn {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        background: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 4px 10px;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.3s ease;
        font-size: 12px;
        color: #4A90E2;
        display: flex;
        align-items: center;
        gap: 4px;
        opacity: 1;
        background: #4A90E2;
        color: white;
        border-color: #4A90E2;
    }

    .video-wrapper {
        position: relative;
        width: 330px;
        height: 233px;
        margin: 0 auto 0px;
        border-radius: 8px;
        overflow: hidden;
        background: #000;
    }

    #video {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    #imagedisplay {
        display: none;
    }

    #countdown {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.5);
        z-index: 10;
    }

    .green-box {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 90%;
        height: 90%;
        transform: translate(-50%, -50%);
        border: 3px dotted limegreen;
        border-radius: 8px;
        pointer-events: none;
    }

    .hidden {
        display: none !important;
    }

    .countdown-text {
        font-size: 72px;
        font-weight: bold;
        color: white;
        text-shadow: 0 0 20px rgba(76, 175, 80, 0.8);
    }

    .processing-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.95);
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 0px;
    }

    .processing-box {
        text-align: center;
        padding: 20px;
    }

    .processing-loader {
        width: 48px;
        height: 48px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #4A90E2;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 16px;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .processing-box .title {
        font-size: 16px;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }

    .processing-box .subtitle {
        font-size: 13px;
        color: #666;
    }

    .warning-message {
        position: absolute;
        bottom: 30px;
        left: 0;
        right: 0;
        text-align: center;
        z-index: 20;
        background-color: #dc2626;
        color: white;
        font-size: 14px;
        padding: 4px 10px;
        border-radius: 8px;
        display: inline-block;
        width: fit-content;
        margin: 0 auto;
    }

    @@keyframes fadeInOut {
        0%, 100% {
            opacity: 0.8;
        }

        50% {
            opacity: 1;
        }
    }

    .button-group {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }

    button {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .cancel-btn {
        background: white;
        color: #666;
        border: 1px solid #ddd;
    }

        .cancel-btn:hover {
            background: #f5f5f5;
            border-color: #bbb;
        }

    .continue-btn {
        background: #4A90E2;
        color: white;
    }

        .continue-btn:hover {
            background: #357ABD;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(74, 144, 226, 0.3);
        }

        .continue-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }
    

</style>



<style>

    #controls-container{
        font-family: 'Univers Next Pro';
    }

