        border-radius: 6px;
        border: 1px solid #D7D7D7;
        font-size: 14px;
        outline: none;
    }

        .input:focus {
            border-color: #000;
        }

    #rememberMe{
        width:14px;
        height:14px;
    }

    /* Remember Me */
    .remember-me {
        display: flex;
        align-items: center;
        margin: 20px 0 20px;
        font-size: 14px;
        color: #444;
    }

    @@media screen and (max-width:575px) {
        .remember-me{
            margin:14px 0px;
        }
    }

        .remember-me input {
            margin-right: 8px;
        }

    /* Button */
    .btn-primary {
        width: 100%;
        padding: 10px;
        background: #000;
        color: #fff;
        border-radius: 6px;
        border: none;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    


        .btn-primary:hover {
            background: #222;
        }
    /* Button */
    .btn-continue {
        width: 100%;
        padding: 10px;
        background: #000;
        color: #fff;
        border-radius: 6px;
        border: none;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }




        .btn-continue:hover {
            background: #222;
        }
    /* Error */
    .error-message {
        color: #d93025;
        font-size: 13px;
        margin-bottom: 10px;
    }




    /* TOTP INPUTS */
    /* .totp-input-wrapper {
        display: flex;
