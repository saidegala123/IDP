<style>
    .user-info-container {
        width: 100%;
    }

    .dialog-left-title{
        font-weight:300;
        color:#161616;
        font-size:20px;
        margin-bottom:14px;
    }

    .dialog-left-sub-title{
        font-weight:400;
        color: #161616;
        font-size: 20px;
        margin-bottom:26px;
    }
    @@media screen and (max-width:575px){
        .dialog-left-sub-title {
            font-size: 16px;
            margin-bottom: 8px;
            margin-top:30px;
        }
    }

    .user-card {
        display: flex;
        padding: 6px 14px;
        align-items: center;
        gap: 4px;
        border-radius: 10px;
        background: #f6f9f3;
        font-family: "Univers Next Pro", sans-serif;
    }

    /* Avatar */
    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
    }

        .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Email text */
    .user-email-box {
        flex: 2;
        font-size: 14px;
        font-weight: 500;
        color: #161616;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    @@media screen and (max-width:575px){
        .user-email-box {
            font-size:15px;
        }
    }

    /* Edit icon */
    .edit-btn {
        background: transparent;
        border: none;
        color: #6b7280;
        font-size: 16px;
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .edit-btn:hover {
            color: #374151;
        }


    /* RIGHT PANEL – NUMBER MATCH */
    .push-number-ui {
        width: 80%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

        .push-number-ui h2 {
            font-size: 18px;
            font-weight: 500;
            margin-bottom: 8px;
        }

    .push-desc {
        font-size: 13px;
        color: #6b6f76;
        max-width: 260px;
        margin-bottom: 26px;
    }

    /* TIMER */
    .push-timer {
        font-size: 12px;
        color: #6b6f76;
    }

    /* USER PILL */
    .push-user-card {
        display: flex;
        align-items: center;
        background: #f6f7f8;
        border-radius: 8px;
        padding: 8px 10px;
    }

        .push-user-card img {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .push-user-card span {
            font-size: 13px;
        }

        .push-user-card .edit-btn {
            margin-left: auto;
            background: none;
            border: none;
            cursor: pointer;
        }
    /* RIGHT PANEL CONTAINER */
    .push-number-ui {
        width: 100%;
        height: 100%;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        font-family: "Univers Next Pro", sans-serif;
    }
    @@media screen and (max-width:575px){
        .push-number-ui {
            padding:0px;
        }
    }

        /* TITLE */
        .push-number-ui h2 {
            font-size: 22px;
            font-weight: 500;
            color: #161616;
            margin-bottom: 6px;
        }

    /* DESCRIPTION */
    .push-desc {
        font-size: 13px;
        color: rgba(22, 22, 22, 0.7);
        font-weight:400;
        margin-bottom: 22px;
    }

    /* NUMBER BOX */
    .number-box {
        border-radius: 8px;
        background: #F3F1F1;
        border: 1px solid #987024;
        display: flex;
        padding:14px 8px;
        align-items: center;
        justify-content: center;
        margin-bottom: 30px;
    }
    @@media screen and (max-width:575px){
        .number-box {
            margin-bottom:12px;
        }
    }

        .number-box .code {
            font-size: 22px;
            font-weight: 500;
            color: #987024;
        }

    /* TIMER */
    .push-timer {
        font-size: 12px;
        color: #6b6f76;
        margin-bottom: 18px;
    }

    /* FOOTER TEXT */
    .code-description {
        font-size: 12px;
        color: #6b6f76;
        max-width: 300px;
        line-height: 1.4;
    }

    .resend-timer{
        color:#987024;
        font-weight:500;
        font-size:13px !important;
    }

    .text-uaeid-instruction {
        font-family: "Univers Next Pro", sans-serif;
        font-weight: 400; /* Regular */
        font-size: 16px;
        line-height: 100%;
        letter-spacing: -0.01em; /* -1% */
        margin-bottom:40px;
        color: #565B63;
        text-align:center;
        line-height: 22px;
    }
    @@media screen and (max-width:575px){
         .text-uaeid-instruction {
             text-align:left;
             font-size:15px;
             margin-bottom:16px;
         }
    }

    #QRCODEForm {
        text-align: center;
        max-width: 320px;
        width: 100%;
    }

    /* Top text */
    .qr-title {
        font-size: 15px;
        color: #5f6b7a;
        margin-bottom: 16px;
        line-height: 1.4;
    }
   
    /* QR white rounded container */
    .qr-card {
        background: #f5f5f5;
        border-radius: 12px;
        padding: 16px;
        display: inline-block;
    }


    /* QR itself */
    .qr-container canvas,
    .qr-container img {
        width: 200px;
        height: 200px;
    }

    /* Steps */
    .qr-steps {
        margin-top: 14px;
        font-size: 14px;
        color: #7a7a7a;
    }

        .qr-steps p {
            margin: 4px 0;
        }

    /* Scan icon look */
    .scan-icon {
        display: inline-block;
        margin-left: 6px;
        background: #f7f7f7;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        padding: 2px 6px;
        font-size: 13px;
    }

    @@media screen and (max-width:575px) {
        .qr-title {
            margin-bottom: 6px;
            font-size: 14px;
        }

        .qr-card {
            padding: 10px;
        }

        .qr-steps {
            margin-top:8px;
        }
    }

    .qr-scanner {
        width: 20px;
        height: 20px;
    }

    .totp-wrapper {
        display: flex;
        gap: 10px;
    }

    .totp-box {
        width: 48px;
        height: 48px;
        text-align: center;
        font-size: 18px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

        .totp-box:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 2px rgba(79,70,229,0.2);
        }

        .totp-box:disabled {
            background-color: #f5f5f5;
            cursor: not-allowed;
        }
       
.verification-success {
    text-align: center;
}

.verification-icon {
    width: 72px;
    height: 72px;
    margin-bottom: 12px;
}

.verification-text {
    font-size: 16px;
    font-weight: 500;
    color: #2c2c2c;
    margin: 0;
}

    .use-webcam-link {
        display: inline-block;
        margin-top: 30px;
