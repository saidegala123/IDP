@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script type="text/javascript">
        var method = "@Model.Method";
        var target = "@Model.Target";
        window.authSchemas = @Html.Raw(JsonSerializer.Serialize(Model.AuthSchemas));
    </script>

    <script type="module">
        import * as UAEKYC from "/idp/icpSdk/index.js";
        window.UAEKYC = UAEKYC;
    </script>

    <script>
        window.APP_CONFIG = {
            logoUrl: '@Url.Content("~/assets/AppLogo.png")',
            privacyPolicyUrl: 'https://example.ae/privacy'
        };
    </script>


    <script>
        window.APP_CONFIG = {
            logoUrl: '@Url.Content("~/assets/AppLogo.png")',
            privacyPolicyUrl: 'https://example.ae/privacy'
        };
        $('#networkOverlay').hide();
    </script>

    <script>
        const inputs = document.querySelectorAll(".totp-box");
        const hiddenInput = document.getElementById("UserTOTP");

        inputs.forEach((input, index) => {

            input.addEventListener("input", () => {
                input.value = input.value.replace(/[^0-9]/g, "");

                if (input.value) {
                    // unlock next box
                    if (index + 1 < inputs.length) {
                        inputs[index + 1].disabled = false;
                        inputs[index + 1].focus();
                    }
                }

                updateHiddenInput();
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace") {
                    if (!input.value && index > 0) {
                        inputs[index].disabled = true;
                        inputs[index - 1].focus();
                    }
                    setTimeout(updateHiddenInput, 0);
                }
            });
        });

        function updateHiddenInput() {
            hiddenInput.value = Array.from(inputs)
                .map(input => input.value)
                .join("");
        }
    </script>


    <script src="~/lib/loginJsCss/helpers.js"></script>
    <script src="~/lib/loginJsCss/face-api.min.js"></script>
    <script src="~/lib/loginJsCss/login1.js" asp-append-version="true"></script>
}
