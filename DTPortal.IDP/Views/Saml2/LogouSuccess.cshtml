
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <noscript>Please enable java script in your browser.</noscript>
    <title>Admin Portal</title>
    <link rel="icon" type="image/x-icon" href="~/assets/logo-single.svg" />


    <!-- Global stylesheets -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700;900&display=swap"
          rel="stylesheet"
          type="text/css" />
   
    <link href="~/assets/css/bootstrap.min.css"
          rel="stylesheet"
          type="text/css" />
    <link href="~/assets/css/bootstrap_limitless.min.css"
          rel="stylesheet"
          type="text/css" />
    <link href="~/lib/sweetalert/dist/sweetalert.css" rel="stylesheet" type="text/css">
   <!-- Core JS files -->
    <script src="~/global_assets/js/main/jquery.min.js"></script>
    <script src="~/global_assets/js/main/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert/dist/sweetalert.min.js"></script>
    <style>
        .HOME {
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(255, 255, 255, 1);
            overflow: hidden;
            --web-view-name: Home;
            --web-view-id: Home;
            --web-scale-on-resize: true;
            --web-enable-deep-linking: true;
        }

        .home {
            display: flex;
            align-items: center;
            min-width: 450px;
            min-height: 300px;
            margin-top: -65px;
            flex-direction: column;
            background-color: rgba(255, 255, 255, 0.5);
            border: solid;
            border-radius: 24px;
            border-color: rgba(255, 222, 173, 0);
            -webkit-box-shadow: 0px 0px 16px 0px rgba(0, 0, 0, 0.3);
            -moz-box-shadow: 0px 0px 16px 0px rgba(0, 0, 0, 0.3);
            box-shadow: 0px 0px 16px 0px rgba(0, 0, 0, 0.3);
        }

        .msg {
            padding: 5px;
            white-space: nowrap;
            text-align: left;
            width: 100%;
            padding-left: 40px;
            font-family: "Source Sans Pro", sans-serif;
            font-style: normal;
            font-weight: bold;
            font-size: 18px;
            color: rgba(64, 64, 64, 1);
        }

        .user {
            padding: 5px;
            white-space: nowrap;
            text-align: left;
            width: 100%;
            padding-left: 40px;
            font-family: "Source Sans Pro", sans-serif;
            font-style: normal;
            font-weight: bold;
            font-size: 18px;
            color: rgba(64, 64, 64, 1);
        }

        .error {
            text-align: center;
            width: 100%;
            margin-top: 20px;
            font-family: Century Gothic;
            font-style: normal;
            font-weight: bold;
            font-size: 25px;
            color: #007e88;
        }
    </style>
</head>
<body>
    <div class="container-fluid" style="padding: 0px">
        <div class="HOME" id="USER" style=" background-image: url('../assets/background.png'); background-repeat: no-repeat; background-size: 100% 100%; ">
            <div class="home">
                <h1 class="error">Success</h1>
                <br>
                @if (ViewBag.Msg != null)
                {
                    <p class="msg">
                        @ViewBag.Msg
                    </p>
                }

            </div>
        </div>
    </div>
</body>

</html>